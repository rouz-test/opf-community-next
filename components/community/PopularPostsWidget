              }`,
            },
            index + 1,
          ),
          h(
            'div',
            { className: 'min-w-0 flex-1' },
            h(
              'p',
              { className: 'line-clamp-2 text-sm font-medium text-gray-900 transition-colors hover:text-orange-500' },
              post.title,
            ),
            h(
              'div',
              { className: 'mt-1.5 flex items-center gap-3 text-xs text-gray-500' },
              h(
                'span',
                { className: 'flex items-center gap-1' },
                h(Heart, { className: 'h-3 w-3' }),
                post.likes,
              ),
              h(
                'span',
                { className: 'flex items-center gap-1' },
                h(MessageSquare, { className: 'h-3 w-3' }),
                post.commentCount ?? 0,
